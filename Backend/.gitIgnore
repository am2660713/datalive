# 🔥 Node.js Backend .gitignore

# dependencies

node_modules/

# environment variables (VERY IMPORTANT)

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# logs

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# runtime data

pids
*.pid
*.seed
*.pid.lock

# coverage

coverage/

# build files

dist/
build/

# OS files

.DS_Store
Thumbs.db

# IDE files

.vscode/
.idea/

# temporary files

*.tmp
*.temp

# uploads (if you store files locally)

uploads/
public/uploads/

# database files (if using local DB like SQLite)

*.sqlite
*.sqlite3

# dotenv backup

.env.backup

# misc

.cache/
npm-cache/
